<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PulseTerm Dark Theme — Design tokens from PulseTerm-zh.pen variables -->

    <!-- Background tokens -->
    <SolidColorBrush x:Key="PulseBgPage"     Color="#0A0E14" />
    <SolidColorBrush x:Key="PulseBgSidebar"  Color="#0D1117" />
    <SolidColorBrush x:Key="PulseBgTerminal" Color="#080C12" />
    <SolidColorBrush x:Key="PulseBgSurface"  Color="#111620" />
    <SolidColorBrush x:Key="PulseBgActive"   Color="#1C2A3F" />
    <SolidColorBrush x:Key="PulseBgHover"    Color="#1A2233" />
    <SolidColorBrush x:Key="PulseBgInput"    Color="#151B26" />

    <!-- Accent tokens -->
    <SolidColorBrush x:Key="PulseAccent"    Color="#00D4AA" />
    <SolidColorBrush x:Key="PulseAccentDim" Color="#00D4AA30" />
    <!-- accent-text is dark (text on accent bg) -->
    <SolidColorBrush x:Key="PulseAccentText" Color="#00D4AA" />

    <!-- Text tokens -->
    <SolidColorBrush x:Key="PulseTextPrimary"   Color="#E0E6ED" />
    <SolidColorBrush x:Key="PulseTextSecondary" Color="#8B9BB4" />
    <SolidColorBrush x:Key="PulseTextTertiary"  Color="#5A6A80" />
    <SolidColorBrush x:Key="PulseTextMuted"     Color="#3D4F63" />

    <!-- Border tokens -->
    <SolidColorBrush x:Key="PulseBorderPrimary"   Color="#1E2A3A" />
    <SolidColorBrush x:Key="PulseBorderSecondary" Color="#253345" />

    <!-- Status tokens -->
    <SolidColorBrush x:Key="PulseStatusConnected"    Color="#00D4AA" />
    <SolidColorBrush x:Key="PulseStatusConnecting"   Color="#FDCB6E" />
    <SolidColorBrush x:Key="PulseStatusDisconnected" Color="#FF6B6B" />

    <!-- Semantic tokens -->
    <SolidColorBrush x:Key="PulseWarning" Color="#FDCB6E" />
    <SolidColorBrush x:Key="PulseError"   Color="#FF6B6B" />
    <SolidColorBrush x:Key="PulseInfo"    Color="#74B9FF" />

    <!-- Tab tokens -->
    <SolidColorBrush x:Key="PulseTabActiveBg"   Color="#111620" />
    <SolidColorBrush x:Key="PulseTabInactiveBg" Color="#0A0E14" />

    <!-- Terminal color tokens -->
    <SolidColorBrush x:Key="PulseTermWhite"   Color="#E0E6ED" />
    <SolidColorBrush x:Key="PulseTermGreen"   Color="#69FF94" />
    <SolidColorBrush x:Key="PulseTermCyan"    Color="#00D4AA" />
    <SolidColorBrush x:Key="PulseTermBlue"    Color="#74B9FF" />
    <SolidColorBrush x:Key="PulseTermYellow"  Color="#FDCB6E" />
    <SolidColorBrush x:Key="PulseTermRed"     Color="#FF6B6B" />
    <SolidColorBrush x:Key="PulseTermMagenta" Color="#D980FA" />

    <!-- Font tokens -->
    <FontFamily x:Key="PulseTerminalFont">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>

</ResourceDictionary>
