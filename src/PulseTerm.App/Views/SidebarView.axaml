<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:views="using:PulseTerm.App.Views"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             xmlns:models="clr-namespace:PulseTerm.Core.Models;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="876"
             x:Class="PulseTerm.App.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

  <Grid Background="{DynamicResource PulseBgSidebar}"
        RowDefinitions="42,36,*,320,40">

    <!-- Row 0: Logo Bar (42px) -->
    <Border Grid.Row="0"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="16,0">
      <StackPanel Orientation="Horizontal"
                  Spacing="10"
                  VerticalAlignment="Center">

        <!-- Logo Icon: gradient rounded rect + pulse line -->
        <Border Width="18" Height="18"
                CornerRadius="4">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#00D4AA" Offset="0" />
              <GradientStop Color="#00A88A" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <!-- Pulse line SVG approximation via Path -->
          <Canvas Width="12" Height="8"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
            <Path Canvas.Left="0" Canvas.Top="0"
                  Stroke="#0A0E14"
                  StrokeThickness="1.5"
                  StrokeJoin="Round"
                  StrokeLineCap="Round"
                  Data="M0,4 L2,4 L4,0 L6,8 L8,2 L10,4 L12,4" />
          </Canvas>
        </Border>

        <!-- App name -->
        <TextBlock Text="PulseTerm"
                   Foreground="{DynamicResource PulseTextPrimary}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />

        <!-- Version -->
        <TextBlock Text="v1.0"
                   Foreground="{DynamicResource PulseTextMuted}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="10"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Row 1: Toolbar (36px) -->
    <Border Grid.Row="1"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">

        <!-- "会话" label -->
        <TextBlock Grid.Column="0"
                   Text="会话"
                   Foreground="{DynamicResource PulseTextSecondary}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="11"
                   FontWeight="Medium"
                   LetterSpacing="1"
                   VerticalAlignment="Center" />

        <!-- Toolbar action buttons -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">

          <!-- Sync button (accent-dim bg) -->
          <Border Width="24" Height="24"
                  CornerRadius="3"
                  Background="{DynamicResource PulseAccentDim}"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10S2 17.523 2 12zm9-4v4.414l3.293 3.293 1.414-1.414L13 11.586V8h-2z"
                      Foreground="{DynamicResource PulseAccent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>

          <!-- Add button -->
          <Button Background="Transparent"
                  Padding="0"
                  Width="24" Height="24"
                  CornerRadius="3"
                  Cursor="Hand"
                  ToolTip.Tip="{x:Static res:Strings.Sessions}">
            <PathIcon Width="13" Height="13"
                      Data="M12 5v14M5 12h14"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>

          <!-- More button -->
          <Button Background="Transparent"
                  Padding="0"
                  Width="24" Height="24"
                  CornerRadius="3"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M5 12h.01M12 12h.01M19 12h.01"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 2: Session Tree (fills remaining space) -->
    <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <views:SessionTreeView DataContext="{Binding SessionTree}"
                             Padding="0,8,0,8" />
    </ScrollViewer>

    <!-- Row 3: Quick Connect + Recent (320px) -->
    <Border Grid.Row="3"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PulseBorderPrimary}">
      <Grid RowDefinitions="36,32,24,*">

        <!-- Quick Connect header -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PulseBorderPrimary}"
                Padding="12,0">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="快速连接"
                       Foreground="{DynamicResource PulseTextSecondary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="11"
                       FontWeight="Medium"
                       LetterSpacing="1"
                       VerticalAlignment="Center" />
            <!-- History button -->
            <Button Grid.Column="1"
                    Background="Transparent"
                    Padding="0"
                    Width="24" Height="24"
                    CornerRadius="3"
                    Cursor="Hand"
                    VerticalAlignment="Center">
              <PathIcon Width="13" Height="13"
                        Data="M3 3h5l1.5 3-1.5 1 .9 1.2A7 7 0 1 1 3 12"
                        Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
          </Grid>
        </Border>

        <!-- Quick Connect Input (32px) -->
        <Border Grid.Row="1"
                Background="{DynamicResource PulseBgInput}"
                Padding="12,0">
          <Grid ColumnDefinitions="Auto,*">
            <PathIcon Grid.Column="0"
                      Width="13" Height="13"
                      Data="M4 17l6-6-6-6M12 19h8"
                      Foreground="{DynamicResource PulseTextTertiary}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding QuickConnect.Input, Mode=TwoWay}"
                     Watermark="用户名@主机名:端口"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource PulseTextSecondary}"
                     CaretBrush="{DynamicResource PulseAccent}"
                     FontFamily="{DynamicResource PulseTerminalFont}"
                     FontSize="11"
                     Padding="0"
                     VerticalAlignment="Center" />
          </Grid>
        </Border>

        <!-- Recent label -->
        <Border Grid.Row="2" Padding="12,0" VerticalAlignment="Center">
          <TextBlock Text="// 最近连接"
                     Foreground="{DynamicResource PulseTextMuted}"
                     FontFamily="{DynamicResource PulseTerminalFont}"
                     FontSize="10" />
        </Border>

        <!-- Recent connections list -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding RecentConnections.Connections}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:SessionProfile">
                <Border Height="32"
                        Padding="12,0"
                        Cursor="Hand"
                        Background="Transparent">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
                    </Style>
                  </Border.Styles>
                  <Grid ColumnDefinitions="Auto,*">
                    <!-- Clock icon -->
                    <PathIcon Grid.Column="0"
                              Width="12" Height="12"
                              Data="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm0 4v6l4 2"
                              Foreground="{DynamicResource PulseTextTertiary}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                    <!-- Connection info -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="1">
                      <TextBlock Foreground="{DynamicResource PulseTextSecondary}"
                                 FontFamily="{DynamicResource PulseTerminalFont}"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{0}@{1}:{2}">
                            <Binding Path="Username" />
                            <Binding Path="Host" />
                            <Binding Path="Port" />
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Row 4: Sidebar Footer (40px) -->
    <Border Grid.Row="4"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">

        <!-- User info: avatar + name -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <!-- Avatar circle -->
          <Border Width="22" Height="22"
                  CornerRadius="11"
                  Background="{DynamicResource PulseAccentDim}">
            <PathIcon Width="12" Height="12"
                      Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"
                      Foreground="{DynamicResource PulseAccent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="root"
                     Foreground="{DynamicResource PulseTextSecondary}"
                     FontFamily="{DynamicResource PulseTerminalFont}"
                     FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Action buttons: notifications + settings -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Button Width="24" Height="24"
                  Background="Transparent"
                  Padding="0"
                  CornerRadius="3"
                  Command="{Binding NotificationsCommand}"
                  ToolTip.Tip="{x:Static res:Strings.Notifications}"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
          <Button Width="24" Height="24"
                  Background="Transparent"
                  Padding="0"
                  CornerRadius="3"
                  Command="{Binding SettingsCommand}"
                  ToolTip.Tip="{x:Static res:Strings.Settings}"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</UserControl>
