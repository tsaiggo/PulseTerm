<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:views="using:PulseTerm.App.Views"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             xmlns:models="clr-namespace:PulseTerm.Core.Models;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="900"
             x:Class="PulseTerm.App.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

  <DockPanel Background="{DynamicResource PulseBgSidebar}">

    <!-- Footer: notifications + settings -->
    <Border DockPanel.Dock="Bottom"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PulseBorderSecondary}"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Text="v1.0"
                   Foreground="{DynamicResource PulseTextTertiary}"
                   VerticalAlignment="Center"
                   FontSize="11" />
        <Button Grid.Column="1"
                Command="{Binding NotificationsCommand}"
                ToolTip.Tip="{x:Static res:Strings.Notifications}"
                Background="Transparent"
                Padding="6"
                Margin="0,0,4,0"
                Cursor="Hand">
          <PathIcon Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                    Width="16" Height="16"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>
        <Button Grid.Column="2"
                Command="{Binding SettingsCommand}"
                ToolTip.Tip="{x:Static res:Strings.Settings}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 00.12-.61l-1.92-3.32a.49.49 0 00-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 00-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 00-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                    Width="16" Height="16"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>
      </Grid>
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="0">

        <!-- Logo area -->
        <Border Padding="20,20,20,12">
          <StackPanel Spacing="2">
            <TextBlock Text="{x:Static res:Strings.AppName}"
                       Foreground="{DynamicResource PulseAccentText}"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="v1.0"
                       Foreground="{DynamicResource PulseTextTertiary}"
                       FontSize="11" />
          </StackPanel>
        </Border>

        <!-- Quick Connect -->
        <Border Padding="16,4,16,16">
          <views:QuickConnectView DataContext="{Binding QuickConnect}" />
        </Border>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource PulseBorderSecondary}"
                Margin="16,0" />

        <!-- Server Groups (TreeView placeholder) -->
        <Border Padding="16,16,16,8">
          <TextBlock Text="{x:Static res:Strings.ServerGroups}"
                     Foreground="{DynamicResource PulseTextSecondary}"
                     FontSize="11"
                     FontWeight="SemiBold" />
        </Border>
        <Border MinHeight="120" Padding="16,0">
          <views:SessionTreeView DataContext="{Binding SessionTree}" />
        </Border>

        <!-- Separator -->
        <Border Height="1"
                Background="{DynamicResource PulseBorderSecondary}"
                Margin="16,0" />

        <!-- Recent Connections -->
        <Border Padding="16,16,16,8">
          <TextBlock Text="{x:Static res:Strings.RecentConnections}"
                     Foreground="{DynamicResource PulseTextSecondary}"
                     FontSize="11"
                     FontWeight="SemiBold" />
        </Border>
        <Border MinHeight="80" Padding="16,0"
                DataContext="{Binding RecentConnections}">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding Connections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:SessionProfile">
                  <Border Padding="4,6" Cursor="Hand"
                          Background="Transparent">
                    <Grid ColumnDefinitions="Auto,*">
                      <Ellipse Grid.Column="0"
                               Width="6" Height="6"
                               Fill="{DynamicResource PulseTextTertiary}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1" Spacing="1">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource PulseTextPrimary}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Foreground="{DynamicResource PulseTextTertiary}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}@{1}:{2}">
                              <Binding Path="Username" />
                              <Binding Path="Host" />
                              <Binding Path="Port" />
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{x:Static res:Strings.ClearAll}"
                    Command="{Binding ClearCommand}"
                    Background="Transparent"
                    Foreground="{DynamicResource PulseTextTertiary}"
                    FontSize="11"
                    Padding="0,4"
                    Margin="0,4,0,0"
                    Cursor="Hand"
                    HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
