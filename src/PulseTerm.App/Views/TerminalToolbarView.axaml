<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="36"
             x:Class="PulseTerm.App.Views.TerminalToolbarView"
             x:DataType="vm:TerminalTabViewModel">

  <Border Background="{DynamicResource PulseBgSurface}"
          BorderThickness="0,0,0,1"
          BorderBrush="{DynamicResource PulseBorderPrimary}"
          Height="36">
    <Grid ColumnDefinitions="Auto,*,Auto">

      <!-- Left: connection title + status indicator -->
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0"
                  Spacing="8">

        <!-- Status dot -->
        <Ellipse Width="7" Height="7"
                 VerticalAlignment="Center">
          <Ellipse.Styles>
            <Style Selector="Ellipse">
              <Setter Property="Fill" Value="{DynamicResource PulseStatusDisconnected}" />
            </Style>
          </Ellipse.Styles>
        </Ellipse>

        <!-- Title: user@host -->
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource PulseTextPrimary}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="280" />

        <!-- Latency -->
        <TextBlock Foreground="{DynamicResource PulseTextSecondary}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Opacity="0.7">
          <TextBlock.Text>
            <MultiBinding StringFormat="{}">
              <Binding Path="Latency" />
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>

      </StackPanel>

      <!-- Right: action buttons -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  Spacing="2">

        <!-- Search -->
        <Button Command="{Binding SearchCommand}"
                ToolTip.Tip="{x:Static res:Strings.Search}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

        <!-- Copy -->
        <Button Command="{Binding CopyCommand}"
                ToolTip.Tip="{x:Static res:Strings.Copy}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

        <!-- Separator -->
        <Border Width="1" Height="16"
                Background="{DynamicResource PulseBorderPrimary}"
                Margin="4,0" />

        <!-- Split (placeholder) -->
        <Button Command="{Binding SplitCommand}"
                ToolTip.Tip="{x:Static res:Strings.Split}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M3 3h8v18H3V3zm10 0h8v18h-8V3z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

        <!-- Broadcast (placeholder) -->
        <Button Command="{Binding ToggleBroadcastCommand}"
                ToolTip.Tip="{x:Static res:Strings.Broadcast}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M1 18v3h3c0-1.66-1.34-3-3-3zm0-4v2c2.76 0 5 2.24 5 5h2c0-3.87-3.13-7-7-7zm0-4v2c4.97 0 9 4.03 9 9h2c0-6.08-4.93-11-11-11zm20-7H3c-1.1 0-2 .9-2 2v3h2V5h18v14h-7v2h7c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

        <!-- Separator -->
        <Border Width="1" Height="16"
                Background="{DynamicResource PulseBorderPrimary}"
                Margin="4,0" />

        <!-- Tunnel -->
        <Button Command="{Binding OpenTunnelCommand}"
                ToolTip.Tip="{x:Static res:Strings.NewTunnel}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

        <!-- Quick Commands -->
        <Button Command="{Binding OpenQuickCommandsCommand}"
                ToolTip.Tip="{x:Static res:Strings.SearchCommands}"
                Background="Transparent"
                Padding="6"
                Cursor="Hand">
          <PathIcon Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
                    Width="14" Height="14"
                    Foreground="{DynamicResource PulseTextSecondary}" />
        </Button>

      </StackPanel>
    </Grid>
  </Border>
</UserControl>
