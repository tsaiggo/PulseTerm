<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="28"
             x:Class="PulseTerm.App.Views.TerminalToolbarView"
             x:DataType="vm:TerminalTabViewModel">
  <Border Background="Transparent"
          BorderThickness="0,0,0,1"
          BorderBrush="{DynamicResource PulseBorderPrimary}"
          Height="28">
    <Grid ColumnDefinitions="Auto,*,Auto">

      <!-- Left: host info + uptime + latency -->
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="14,0,0,0"
                  Spacing="12">

        <!-- host: root@server:~ in accent color -->
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource PulseAccent}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="260" />

        <!-- Uptime (hidden until we have real data) -->
        <TextBlock Text="uptime: —"
                   Foreground="{DynamicResource PulseTextMuted}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="10"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsConnected}" />

        <!-- Pipe divider -->
        <TextBlock Text="|"
                   Foreground="{DynamicResource PulseTextMuted}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="10"
                   VerticalAlignment="Center"
                   IsVisible="{Binding Latency, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <!-- Latency in status-connected color -->
        <TextBlock Foreground="{DynamicResource PulseStatusConnected}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="10"
                   VerticalAlignment="Center"
                   IsVisible="{Binding Latency, Converter={x:Static ObjectConverters.IsNotNull}}">
          <TextBlock.Text>
            <MultiBinding StringFormat="latency: {0:fff}ms">
              <Binding Path="Latency" />
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>

      </StackPanel>

      <!-- Right: action icon buttons (24x22 each) -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Spacing="4">

        <!-- Search -->
        <Button Command="{Binding SearchCommand}"
                ToolTip.Tip="{x:Static res:Strings.Search}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextMuted}" />
        </Button>

        <!-- Copy -->
        <Button Command="{Binding CopyCommand}"
                ToolTip.Tip="{x:Static res:Strings.Copy}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextMuted}" />
        </Button>

        <!-- Split -->
        <Button Command="{Binding SplitCommand}"
                ToolTip.Tip="{x:Static res:Strings.Split}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M3 3h8v18H3V3zm10 0h8v18h-8V3z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextMuted}" />
        </Button>

        <!-- Tunnel -->
        <Button Command="{Binding OpenTunnelCommand}"
                ToolTip.Tip="{x:Static res:Strings.NewTunnel}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextMuted}" />
        </Button>

        <!-- Quick Commands -->
        <Button Command="{Binding OpenQuickCommandsCommand}"
                ToolTip.Tip="{x:Static res:Strings.SearchCommands}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M13 10V3L4 14h7v7l9-11h-7z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextMuted}" />
        </Button>

        <!-- Sync Group (active state, bg-active + accent) -->
        <Button Background="{DynamicResource PulseBgActive}"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand"
                ToolTip.Tip="{x:Static res:Strings.SyncGroup}">
          <PathIcon Data="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseAccent}" />
        </Button>

        <!-- Broadcast -->
        <Button Command="{Binding ToggleBroadcastCommand}"
                ToolTip.Tip="{x:Static res:Strings.Broadcast}"
                Background="Transparent"
                Width="24" Height="22"
                Padding="0"
                CornerRadius="3"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand">
          <PathIcon Data="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"
                    Width="12" Height="12"
                    Foreground="{DynamicResource PulseTextTertiary}" />
        </Button>

      </StackPanel>
    </Grid>
  </Border>
</UserControl>
