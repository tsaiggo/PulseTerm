<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="400"
             x:Class="PulseTerm.App.Views.SessionTreeView"
             x:DataType="vm:SessionTreeViewModel">

  <TreeView ItemsSource="{Binding Nodes}"
            SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
            Background="Transparent"
            Padding="0,0,0,0">

    <TreeView.Styles>
      <Style Selector="TreeViewItem">
        <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
      </Style>
      <!-- Remove default selection highlight; we manage it manually -->
      <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="Transparent" />
      </Style>
    </TreeView.Styles>

    <TreeView.ItemTemplate>
      <TreeDataTemplate ItemsSource="{Binding Children}"
                        x:DataType="vm:SessionTreeNodeViewModel">

        <!-- Group row -->
        <Panel>
          <Border IsVisible="{Binding IsGroup}"
                  Height="30"
                  Padding="12,0"
                  Background="Transparent"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">

              <!-- Chevron: down when expanded, right when collapsed -->
              <PathIcon Width="12" Height="12"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PulseTextTertiary}">
                <PathIcon.Styles>
                  <Style Selector="PathIcon">
                    <Setter Property="Data" Value="M9 18l6-6-6-6" />
                  </Style>
                </PathIcon.Styles>
              </PathIcon>

              <!-- Folder icon -->
              <PathIcon Width="13" Height="13"
                        Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                        Foreground="{DynamicResource PulseTextTertiary}"
                        VerticalAlignment="Center" />

              <!-- Group name -->
              <TextBlock Text="{Binding Name}"
                         Foreground="{DynamicResource PulseTextPrimary}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />

              <!-- Child count -->
              <TextBlock Text="{Binding Children.Count}"
                         Foreground="{DynamicResource PulseTextTertiary}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center" />

            </StackPanel>
          </Border>

          <!-- Server / session row -->
          <Border IsVisible="{Binding !IsGroup}"
                  Height="28"
                  Padding="36,0,12,0"
                  Cursor="Hand"
                  Background="Transparent">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
              </Style>
            </Border.Styles>
            <Border.ContextMenu>
              <ContextMenu x:DataType="vm:SessionTreeNodeViewModel">
                <MenuItem Header="{x:Static res:Strings.Connect}"
                          Command="{Binding $parent[TreeView].((vm:SessionTreeViewModel)DataContext).ConnectCommand}"
                          IsVisible="{Binding !IsGroup}" />
                <MenuItem Header="{x:Static res:Strings.Edit}"
                          Command="{Binding $parent[TreeView].((vm:SessionTreeViewModel)DataContext).EditSessionCommand}"
                          IsVisible="{Binding !IsGroup}" />
                <Separator IsVisible="{Binding !IsGroup}" />
                <MenuItem Header="{x:Static res:Strings.Delete}"
                          Command="{Binding $parent[TreeView].((vm:SessionTreeViewModel)DataContext).DeleteSessionCommand}"
                          IsVisible="{Binding !IsGroup}" />
              </ContextMenu>
            </Border.ContextMenu>
            <Grid ColumnDefinitions="Auto,*">

              <!-- Status dot -->
              <Ellipse Grid.Column="0"
                       Width="7" Height="7"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Fill="{DynamicResource PulseStatusDisconnected}" />

              <!-- Server name -->
              <TextBlock Grid.Column="1"
                         Text="{Binding Name}"
                         Foreground="{DynamicResource PulseTextSecondary}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="11"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
            </Grid>
          </Border>
        </Panel>

      </TreeDataTemplate>
    </TreeView.ItemTemplate>
  </TreeView>

</UserControl>
