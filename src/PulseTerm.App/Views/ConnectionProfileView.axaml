<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PulseTerm.App.ViewModels"
        xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
        xmlns:models="clr-namespace:PulseTerm.Core.Models;assembly=PulseTerm.Core"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="PulseTerm.App.Views.ConnectionProfileView"
        x:DataType="vm:ConnectionProfileViewModel"
        Title="{x:Static res:Strings.ConnectionProfile}"
        Width="500" Height="600"
        CanResize="False"
        Background="{DynamicResource PulseBgPage}"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Height" Value="34" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="Height" Value="34" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="Height" Value="34" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseBgPage}" />
      <Setter Property="Padding" Value="24,8" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="24,8" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseAccentText}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseAccentDim}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="24">

    <!-- Header -->
    <TextBlock DockPanel.Dock="Top"
               Text="{x:Static res:Strings.ConnectionProfile}"
               Foreground="{DynamicResource PulseTextPrimary}"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,20" />

    <!-- Buttons at bottom -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12"
                Margin="0,20,0,0">
      <Button Classes="outline"
              Content="{x:Static res:Strings.TestConnection}"
              Command="{Binding TestConnectionCommand}" />
      <Button Classes="secondary"
              Content="{x:Static res:Strings.Cancel}"
              Command="{Binding CancelCommand}" />
      <Button Classes="primary"
              Content="{x:Static res:Strings.Save}"
              Command="{Binding SaveCommand}" />
    </StackPanel>

    <!-- Separator -->
    <Border DockPanel.Dock="Bottom"
            Height="1"
            Background="{DynamicResource PulseBorderSecondary}"
            Margin="0,16,0,0" />

    <!-- Form fields -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">

        <!-- Security Warning -->
        <Border Background="#FFF4E6"
                BorderBrush="#FFB74D"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="{x:Static res:Strings.SecurityWarning}"
                       Foreground="#E65100"
                       FontWeight="SemiBold"
                       FontSize="13" />
            <TextBlock Text="{x:Static res:Strings.PasswordStorageWarning}"
                       Foreground="#5D4037"
                       FontSize="12"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Name -->
        <StackPanel>
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.Name}" />
          <TextBox Text="{Binding Name}" />
        </StackPanel>

        <!-- Host -->
        <StackPanel>
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.Host}" />
          <TextBox Text="{Binding Host}" Watermark="192.168.1.1" />
        </StackPanel>

        <!-- Port -->
        <StackPanel>
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.Port}" />
          <NumericUpDown Value="{Binding Port}"
                         Minimum="1"
                         Maximum="65535"
                         Increment="1"
                         FormatString="0" />
        </StackPanel>

        <!-- Username -->
        <StackPanel>
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.Username}" />
          <TextBox Text="{Binding Username}" Watermark="root" />
        </StackPanel>

        <!-- Auth Method -->
        <StackPanel>
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.AuthMethodLabel}" />
          <ComboBox SelectedItem="{Binding AuthMethod}">
            <models:AuthMethod>Password</models:AuthMethod>
            <models:AuthMethod>PrivateKey</models:AuthMethod>
          </ComboBox>
        </StackPanel>

        <!-- Password (visible when Password auth) -->
        <StackPanel IsVisible="{Binding IsPasswordAuth}">
          <TextBlock Classes="field-label" Text="{x:Static res:Strings.Password}" />
          <TextBox Text="{Binding Password}"
                   PasswordChar="&#x2022;"
                   RevealPassword="False" />
        </StackPanel>

        <!-- Private Key Path (visible when Key auth) -->
        <StackPanel IsVisible="{Binding IsKeyAuth}" Spacing="8">
          <StackPanel>
            <TextBlock Classes="field-label" Text="{x:Static res:Strings.PrivateKey}" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0" Text="{Binding PrivateKeyPath}" />
              <Button Grid.Column="1"
                      Classes="secondary"
                      Content="{x:Static res:Strings.BrowseKeyFile}"
                      Command="{Binding BrowseKeyFileCommand}"
                      Margin="8,0,0,0" />
            </Grid>
          </StackPanel>

          <StackPanel>
            <TextBlock Classes="field-label" Text="{x:Static res:Strings.Passphrase}" />
            <TextBox Text="{Binding PrivateKeyPassphrase}"
                     PasswordChar="&#x2022;"
                     RevealPassword="False" />
          </StackPanel>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</Window>
