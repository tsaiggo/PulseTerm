<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PulseTerm.App.ViewModels"
        xmlns:views="using:PulseTerm.App.Views"
        xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="PulseTerm.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static res:Strings.AppName}"
        Width="1440" Height="900"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource PulseBgPage}"
        WindowStartupLocation="CenterScreen">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+T" Command="{Binding TabBar.AddTabCommand}" />
    <KeyBinding Gesture="Ctrl+W" Command="{Binding TabBar.CloseActiveTabCommand}" />
    <KeyBinding Gesture="Ctrl+Tab" Command="{Binding TabBar.NextTabCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding TabBar.PreviousTabCommand}" />
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="*,Auto">

    <!-- Row 0: Content area (sidebar + main) -->
    <Grid Grid.Row="0" ColumnDefinitions="260,Auto,*">

      <!-- Sidebar -->
      <views:SidebarView Grid.Column="0" DataContext="{Binding Sidebar}" />

      <!-- Sidebar border -->
      <Border Grid.Column="1"
              Width="1"
              Background="{DynamicResource PulseBorderPrimary}" />

      <!-- Main area (tab bar + terminal) -->
      <Grid Grid.Column="2" RowDefinitions="36,*">

        <!-- Tab bar -->
        <views:TabBarView Grid.Row="0" DataContext="{Binding TabBar}" />

        <!-- Terminal area placeholder -->
        <Border Grid.Row="1"
                Background="{DynamicResource PulseBgPage}">
          <TextBlock Text="{x:Static res:Strings.AppName}"
                     Foreground="{DynamicResource PulseTextMuted}"
                     FontSize="24"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="0.3" />
        </Border>

      </Grid>
    </Grid>

    <!-- Row 1: Status bar -->
    <Border Grid.Row="1"
            Height="24"
            Background="{DynamicResource PulseBgSidebar}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="12,0"
            DataContext="{Binding StatusBar}">
      <Border.DataTemplates>
        <DataTemplate DataType="vm:StatusBarViewModel"
                      x:DataType="vm:StatusBarViewModel">
          <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Left: wifi icon + connection + latency + uptime -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="14"
                        VerticalAlignment="Center">

              <!-- Wifi icon (only when connected) -->
              <PathIcon IsVisible="{Binding IsConnected}"
                        Data="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"
                        Width="12" Height="12"
                        Foreground="{DynamicResource PulseStatusConnected}" />

              <!-- Connection info: SSH • host:port -->
              <TextBlock Text="{Binding ConnectionInfo}"
                         Foreground="{DynamicResource PulseTextSecondary}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center">
                <TextBlock.IsVisible>
                  <Binding Path="ConnectionInfo">
                    <Binding.Converter>
                      <x:Static Member="StringConverters.IsNotNullOrEmpty" />
                    </Binding.Converter>
                  </Binding>
                </TextBlock.IsVisible>
              </TextBlock>

              <!-- Divider -->
              <Border Width="1" Height="12"
                      Background="{DynamicResource PulseBorderSecondary}"
                      VerticalAlignment="Center">
                <Border.IsVisible>
                  <Binding Path="Latency">
                    <Binding.Converter>
                      <x:Static Member="StringConverters.IsNotNullOrEmpty" />
                    </Binding.Converter>
                  </Binding>
                </Border.IsVisible>
              </Border>

              <!-- Latency in accent color -->
              <TextBlock Foreground="{DynamicResource PulseAccent}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center">
                <TextBlock.Text>
                  <MultiBinding StringFormat="Latency: {0}">
                    <Binding Path="Latency" />
                  </MultiBinding>
                </TextBlock.Text>
                <TextBlock.IsVisible>
                  <Binding Path="Latency">
                    <Binding.Converter>
                      <x:Static Member="StringConverters.IsNotNullOrEmpty" />
                    </Binding.Converter>
                  </Binding>
                </TextBlock.IsVisible>
              </TextBlock>

              <!-- Divider -->
              <Border Width="1" Height="12"
                      Background="{DynamicResource PulseBorderSecondary}"
                      VerticalAlignment="Center">
                <Border.IsVisible>
                  <Binding Path="Uptime">
                    <Binding.Converter>
                      <x:Static Member="StringConverters.IsNotNullOrEmpty" />
                    </Binding.Converter>
                  </Binding>
                </Border.IsVisible>
              </Border>

              <!-- Uptime -->
              <TextBlock Foreground="{DynamicResource PulseTextTertiary}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center">
                <TextBlock.Text>
                  <MultiBinding StringFormat="↑ {0}">
                    <Binding Path="Uptime" />
                  </MultiBinding>
                </TextBlock.Text>
                <TextBlock.IsVisible>
                  <Binding Path="Uptime">
                    <Binding.Converter>
                      <x:Static Member="StringConverters.IsNotNullOrEmpty" />
                    </Binding.Converter>
                  </Binding>
                </TextBlock.IsVisible>
              </TextBlock>

            </StackPanel>

            <!-- Right: terminal type + window size + encoding -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding TerminalType}"
                         Foreground="{DynamicResource PulseTextMuted}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center" />
              <TextBlock Text="{Binding WindowSize}"
                         Foreground="{DynamicResource PulseTextMuted}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center" />
              <TextBlock Text="{Binding Encoding}"
                         Foreground="{DynamicResource PulseTextMuted}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="10"
                         VerticalAlignment="Center" />
            </StackPanel>

          </Grid>
        </DataTemplate>
      </Border.DataTemplates>
      <ContentControl Content="{Binding}" />
    </Border>

  </Grid>
</Window>
